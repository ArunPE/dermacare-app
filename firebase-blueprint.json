{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["patient", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Doctor": {
      "title": "Doctor",
      "description": "Doctor profile and specialty",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "specialty": { "type": "string" },
        "bio": { "type": "string" },
        "image": { "type": "string" },
        "experience": { "type": "string" },
        "rating": { "type": "number" }
      },
      "required": ["id", "name", "specialty"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Appointment booking details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "doctorId": { "type": "string" },
        "doctorName": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "phoneNumber": { "type": "string", "description": "Patient contact number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "doctorId", "date", "time", "status"]
    },
    "Report": {
      "title": "Report",
      "description": "Patient medical reports",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "title": { "type": "string" },
        "fileUrl": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "title", "fileUrl"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/doctors/{doctorId}": {
      "schema": "Doctor",
      "description": "Doctor profile documents"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Appointment booking documents"
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Patient report documents"
    }
  }
}
