rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName, photoURL, role, createdAt
    //
    // Collection: doctors
    // Fields: id, name, specialty, bio, image, experience, rating
    //
    // Collection: appointments
    // Fields: id, patientId, patientName, doctorId, doctorName, date, time, status, createdAt
    //
    // Collection: reports
    // Fields: id, patientId, title, fileUrl, date
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "arun.pt.kumar@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['patient', 'admin'];
    }

    function isValidAppointment(data) {
      return data.keys().hasAll(['patientId', 'doctorId', 'date', 'time', 'status', 'phoneNumber']) &&
             data.patientId is string &&
             data.doctorId is string &&
             data.date is string &&
             data.time is string &&
             data.phoneNumber is string &&
             data.phoneNumber.matches("^(\\+91)?[6-9]\\d{9}$") &&
             data.status in ['pending', 'confirmed', 'cancelled'];
    }

    function isValidReport(data) {
      return data.keys().hasAll(['patientId', 'title', 'fileUrl']) &&
             data.patientId is string &&
             data.title is string &&
             data.fileUrl is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isOwner(userId) && request.resource.data.role == 'patient' || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
    }

    match /doctors/{doctorId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /appointments/{appointmentId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.patientId || isAdmin());
      allow create: if isAuthenticated() && isValidAppointment(request.resource.data) && 
                    (request.auth.uid == request.resource.data.patientId || isAdmin());
      allow update: if isAuthenticated() && isValidAppointment(request.resource.data) && 
                    (request.auth.uid == resource.data.patientId || isAdmin());
      allow delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.patientId || isAdmin());
      allow create: if isAuthenticated() && isValidReport(request.resource.data) && 
                    (request.auth.uid == request.resource.data.patientId || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
